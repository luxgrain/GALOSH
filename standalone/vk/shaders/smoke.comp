#version 450
/* smoke.comp — [V2.0 Phase B1] plumbing check kernel.
 * out[i] = 2*in[i] + 1  (trivially verifiable on readback).
 * B1 の配管確認用: 検証容易な一次変換のみ。 */
layout(local_size_x = 256) in;

layout(std430, binding = 0) readonly buffer InBuf  { float src[]; };
layout(std430, binding = 1) writeonly buffer OutBuf { float dst[]; };
layout(push_constant) uniform PC { uint n; } pc;

void main()
{
  uint i = gl_GlobalInvocationID.x;
  if(i >= pc.n) return;
  dst[i] = 2.0 * src[i] + 1.0;
}
