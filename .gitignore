standalone/_split_core.py
standalone/archive/
standalone/*.bak
standalone/*.backup

# --- /c/tmp rescue archive (6.5 GB of prior debug bins / dirs, 2026-05-16) ---
tools/_tmp_archive_*/

# --- Allow specific text files even with broad rules above ---
!README.md
!CONTRIBUTING*.md
!docs/*.md
!standalone/*.txt
!scripts/*.txt
standalone/*.clbin

# --- Organize 2026-07-02: archived-for-user-deletion area (NEVER commit) ---
_ARCHIVE/

# --- USPTO provisional materials (private, never public) ---
docs/patent/
tools/patent_figures/

# --- Harness scratch ---
standalone/tests/_smoke_tmp/

